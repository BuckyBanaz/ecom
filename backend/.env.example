# Application Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Database Connection (PostgreSQL)
# For local Postgres, replace username, password, host, port, and database name
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecom_db?schema=public"

# Security Configuration
JWT_SECRET="super-secret-ecom-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Redis Cache Config
REDIS_URL="redis://localhost:6379"

# Optional Cloud Storage (e.g. Cloudinary) for Image Uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
