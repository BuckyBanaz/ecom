datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Users Model (Customers & Admins)
model User {
  id           String     @id @default(uuid())
  name         String
  firstName    String?    @map("first_name")
  lastName     String?    @map("last_name")
  email        String     @unique
  phone        String?    @unique
  passwordHash String     @map("password_hash")
  role         String     @default("customer") // customer, admin, superadmin, moderator
  avatar       String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  orders       Order[]
  wishlists    Wishlist[]

  @@map("users")
}

// 2. Groups Model (High-level category collections)
model Group {
  id          String   @id
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("groups")
}

// 2.5. Brands Model
model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  logo      String?
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("brands")
}

// 3. Categories Model
model Category {
  id                 String              @id @default(uuid())
  slug               String              @unique
  name               String
  image              String
  group              String // indoor, outdoor, bulbs, business, smart, accessories
  parentId           String?             @map("parent_id")
  parent             Category?           @relation("CategoryParent", fields: [parentId], references: [id])
  children           Category[]          @relation("CategoryParent")
  categoryAttributes CategoryAttribute[]
  products           Product[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("categories")
}

// 3.5. Products Model
model Product {
  id                     String                  @id @default(uuid())
  slug                   String                  @unique
  name                   String
  brandId                String?                 @map("brand_id")
  brand                  Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId             String                  @map("category_id")
  category               Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  price                  Float
  oldPrice               Float?                  @map("old_price")
  rating                 Float                   @default(0.0)
  reviewCount            Int                     @default(0) @map("review_count")
  image                  String
  inStock                Boolean                 @default(true) @map("in_stock")
  description            String
  shortDescription       String                  @default("") @map("short_description")
  specs                  Json                    @default("{}")
  seoTitle               String?
  seoDescription         String?
  seoKeywords            String?
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  reviews                Review[]
  wishlists              Wishlist[]
  productAttributeValues ProductAttributeValue[]
  variants               ProductVariant[]

  @@map("products")
}

// 4. Attributes Model
model Attribute {
  id                     String                  @id @default(uuid())
  name                   String
  slug                   String                  @unique
  type                   String // select, multi_select, range, boolean
  visibility             String                  @default("both") // admin, filter, both
  attributeValues        AttributeValue[]
  categoryAttributes     CategoryAttribute[]
  productAttributeValues ProductAttributeValue[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  @@map("attributes")
}

// 4.5. Attribute Values Model
model AttributeValue {
  id                     String                  @id @default(uuid())
  attributeId            String                  @map("attribute_id")
  attribute              Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value                  String
  colorCode              String?                 @map("color_code") // for hex codes of colors
  productAttributeValues ProductAttributeValue[]
  variantAttributeValues VariantAttributeValue[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  @@map("attribute_values")
}

// 5. Category Attributes Mapping Model
model CategoryAttribute {
  id          String    @id @default(uuid())
  categoryId  String    @map("category_id")
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId String    @map("attribute_id")
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([categoryId, attributeId])
  @@map("category_attributes")
}

// 5.5. Product Attribute Values Mapping Model
model ProductAttributeValue {
  id               String         @id @default(uuid())
  productId        String         @map("product_id")
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId      String         @map("attribute_id")
  attribute        Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValueId String         @map("attribute_value_id")
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([productId, attributeId, attributeValueId])
  @@map("product_attribute_values")
}

// 6. Product Variants Model
model ProductVariant {
  id                     String                  @id @default(uuid())
  productId              String                  @map("product_id")
  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                    String                  @unique
  stock                  Int                     @default(0)
  price                  Float?                  // overrides product price if set
  variantAttributeValues VariantAttributeValue[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  @@map("product_variants")
}

// 6.5. Variant Attribute Values Mapping Model
model VariantAttributeValue {
  id               String         @id @default(uuid())
  variantId        String         @map("variant_id")
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValueId String         @map("attribute_value_id")
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([variantId, attributeValueId])
  @@map("variant_attribute_values")
}

// 4. Reviews Model
model Review {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  title     String
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

// 5. Orders Model
model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @map("order_number")
  userId          String?     @map("user_id")
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName    String      @map("customer_name")
  customerEmail   String      @map("customer_email")
  subtotal        Float
  shipping        Float
  total           Float
  status          String      @default("pending") // pending, processing, shipped, delivered, cancelled
  paymentMethod   String      @map("payment_method")
  shippingAddress String      @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  items           OrderItem[]

  @@map("orders")
}

// 6. Order Items Model
model OrderItem {
  id           String  @id @default(uuid())
  orderId      String  @map("order_id")
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String? @map("product_id")
  productName  String  @map("product_name")
  productImage String  @map("product_image")
  quantity     Int
  price        Float
  variant      String?

  @@map("order_items")
}

// 7. Wishlists Model
model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("wishlists")
}

// 8. CMS Configuration Model
model CmsConfig {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_config")
}

// 9. Mega Menu Model
model MegaMenu {
  id        String   @id @default(uuid())
  menu      String
  slug      String   @unique
  sections  Json     @default("[]") // Array of sections and items
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mega_menus")
}
